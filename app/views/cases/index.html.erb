<div class="legal-dashboard">
  <h1>Legal Case Management System</h1>
  <p>Group 05D2 - DevOps Project DO-17</p>

  <table class="case-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>Case Title</th>
        <th>Practice Area</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @cases.each do |c| %>
        <tr>
          <td><%= c[:id] %></td>
          <td><%= c[:title] %></td>
          <td><%= c[:practice_area] %></td>
          <td><span class="status-badge <%= c[:status].downcase.gsub(' ', '-') %>"><%= c[:status] %></span></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<style>
  .legal-dashboard { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; padding: 20px; }
  .case-table { width: 100%; border-collapse: collapse; margin-top: 20px; }
  .case-table th, .case-table td { border: 1px solid #ddd; padding: 12px; text-align: left; }
  .case-table th { background-color: #2c3e50; color: white; }
  .status-badge { padding: 4px 8px; border-radius: 4px; font-size: 0.85em; }
  .open { background-color: #e67e22; color: white; }
  .closed { background-color: #95a5a6; color: white; }
  .in-progress { background-color: #3498db; color: white; }
</style>
